# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=3000
APP_NAME=afsys

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/afsys_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Cache ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate a secure random string: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_a_32_char_random_secret
JWT_EXPIRY_HOURS=1
JWT_REFRESH_EXPIRY_DAYS=30

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@afsys.example.com

# ─── Logging ──────────────────────────────────────────────────────────────────
# error | warn | info | debug | trace
LOG_LEVEL=info

# ─── External Integrations ────────────────────────────────────────────────────
# Add third-party API keys here (never commit real values)
# EXAMPLE_API_KEY=
# EXAMPLE_API_SECRET=
